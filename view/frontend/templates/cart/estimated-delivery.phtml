<?php
/**
 * Panth AdvancedCart - Estimated Delivery Date (Hyva)
 *
 * @var $block \Magento\Framework\View\Element\Template
 * @var $escaper \Magento\Framework\Escaper
 */
declare(strict_types=1);

/** @var \Panth\AdvancedCart\ViewModel\CartEnhancements $viewModel */
$viewModel = $block->getData('view_model');

if (!$viewModel->isFeatureEnabled('estimated_delivery')) {
    return;
}

$delivery = $viewModel->getEstimatedDeliveryRange();
?>

<div class="panth-estimated-delivery flex items-center gap-2 rounded-lg bg-blue-50 border border-blue-200 p-3 mb-4">
    <svg class="w-5 h-5 text-blue-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
    </svg>
    <div>
        <p class="text-sm text-blue-800 m-0">
            <span class="font-semibold"><?= $escaper->escapeHtml(__($delivery['label'])) ?>:</span>
            <?= $escaper->escapeHtml($delivery['min_date']) ?> - <?= $escaper->escapeHtml($delivery['max_date']) ?>
        </p>
    </div>
</div>
