<?php
/**
 * Panth AdvancedCart - Cart Savings Display (Luma)
 *
 * @var $block \Magento\Framework\View\Element\Template
 * @var $escaper \Magento\Framework\Escaper
 */

/** @var \Panth\AdvancedCart\ViewModel\CartEnhancements $viewModel */
$viewModel = $block->getData('view_model');

if (!$viewModel->isFeatureEnabled('cart_savings') || !$viewModel->hasCartSavings()) {
    return;
}
?>

<div style="display: flex; align-items: center; gap: 8px; border-radius: 8px; background: #F0FDF4; border: 1px solid #BBF7D0; padding: 12px; margin-bottom: 16px;">
    <svg width="20" height="20" style="color: #16A34A; flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/>
    </svg>
    <p style="font-size: 14px; font-weight: 600; color: #166534; margin: 0;">
        <?= $escaper->escapeHtml(__('You save')) ?>
        <span style="color: #16A34A;"><?= $escaper->escapeHtml($viewModel->getFormattedCartSavings()) ?></span>
        <?= $escaper->escapeHtml(__('on this order!')) ?>
    </p>
</div>
