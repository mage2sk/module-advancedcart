 */

/** @var \Panth\AdvancedCart\ViewModel\CartEnhancements $viewModel */
$viewModel = $block->getData('view_model');

$isEnhanced = $viewModel && $viewModel->isFeatureEnabled('empty_cart');
$heading = $isEnhanced ? $viewModel->getEmptyCartHeading() : 'Your cart is empty';
