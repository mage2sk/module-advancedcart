.panth-empty-cart .ec-btn { display: inline-flex; align-items: center; gap: 8px; background: var(--color-primary, #0D9488); color: #fff; padding: 12px 32px; border-radius: 8px; text-decoration: none; font-size: 16px; font-weight: 500; transition: background 0.2s; }
.panth-empty-cart .ec-btn:hover { opacity: 0.9; }
