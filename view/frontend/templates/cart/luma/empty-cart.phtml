$buttonLabel = $isEnhanced ? $viewModel->getEmptyCartButtonLabel() : 'Continue Shopping';
?>

<style>
.panth-empty-cart { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 48px 16px; text-align: center; max-width: 400px; margin: 0 auto; }
.panth-empty-cart .ec-icon { width: 96px; height: 96px; border-radius: 50%; background: #F3F4F6; display: flex; align-items: center; justify-content: center; margin-bottom: 24px; }
.panth-empty-cart .ec-icon svg { width: 48px; height: 48px; color: #9CA3AF; }
.panth-empty-cart h2 { font-size: 24px; font-weight: 700; color: #1F2937; margin-bottom: 12px; }
