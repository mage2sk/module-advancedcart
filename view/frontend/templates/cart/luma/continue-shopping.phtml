<?php
/**
 * Panth AdvancedCart - Continue Shopping Button (Luma)
 *
 * @var $block \Magento\Framework\View\Element\Template
 * @var $escaper \Magento\Framework\Escaper
 */

/** @var \Panth\AdvancedCart\ViewModel\CartEnhancements $viewModel */
$viewModel = $block->getData('view_model');

if (!$viewModel->isFeatureEnabled('continue_shopping')) {
    return;
}

$label = $viewModel->getContinueShoppingLabel();
$url = $viewModel->getContinueShoppingUrl();
?>

<div style="margin-bottom: 16px;">
    <a href="<?= $escaper->escapeUrl($url) ?>"
       style="display: inline-flex; align-items: center; gap: 8px; font-size: 14px; color: var(--color-primary, #0D9488); text-decoration: none; transition: color 0.2s;">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        <?= $escaper->escapeHtml(__($label)) ?>
    </a>
</div>
