<div class="panth-trust-badges mt-4 pt-4 border-t border-gray-200">
    <div class="grid grid-cols-3 gap-2">
        <?php foreach ($badges as $key => $badge): ?>
            <div class="flex flex-col items-center text-center gap-1 p-2">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <?= /* @noEscape */ $icons[$badge['icon']] ?? '' ?>
                </svg>
                <span class="text-xs text-gray-600 leading-tight"><?= $escaper->escapeHtml(__($badge['label'])) ?></span>
            </div>
        <?php endforeach; ?>
    </div>
</div>
