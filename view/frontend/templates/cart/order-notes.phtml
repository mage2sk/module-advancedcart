<?php
/**
 * Panth AdvancedCart - Order Notes (Hyva)
 *
 * @var $block \Magento\Framework\View\Element\Template
 * @var $escaper \Magento\Framework\Escaper
 */
declare(strict_types=1);

/** @var \Panth\AdvancedCart\ViewModel\CartEnhancements $viewModel */
$viewModel = $block->getData('view_model');

if (!$viewModel->isFeatureEnabled('order_notes')) {
    return;
}

$placeholder = $viewModel->getOrderNotesPlaceholder();
$maxLength = $viewModel->getOrderNotesMaxLength();
$existingNote = $viewModel->getExistingOrderNote();
$saveUrl = $block->getUrl('advancedcart/cart/saveNote');
?>

<script>
    function initOrderNotes() {
        return {
            note: '<?= $escaper->escapeJs($existingNote) ?>',
            saving: false,
            saved: false,
            timeout: null,
            saveNote() {
                if (this.timeout) clearTimeout(this.timeout);
                this.timeout = setTimeout(() => {
                    this.saving = true;
                    this.saved = false;
                    fetch('<?= $escaper->escapeJs($saveUrl) ?>', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: 'form_key=' + hyva.getFormKey() + '&note=' + encodeURIComponent(this.note)
                    })
                    .then(res => res.json())
                    .then(data => {
                        this.saving = false;
                        if (data.success) {
                            this.saved = true;
                            setTimeout(() => this.saved = false, 2000);
                        }
                    })
                    .catch(() => { this.saving = false; });
                }, 800);
            }
        };
    }
</script>

<div class="panth-order-notes mt-6" x-data="initOrderNotes()">
    <details class="group" open>
        <summary class="list-none flex items-center gap-2 cursor-pointer py-2 font-semibold text-base select-none">
            <svg class="w-5 h-5 text-primary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
            <span><?= $escaper->escapeHtml(__('Order Notes')) ?></span>
            <span x-show="saved" x-transition class="text-xs text-green-600 font-normal ml-auto">Saved</span>
            <span x-show="saving" class="text-xs text-gray-400 font-normal ml-auto">Saving...</span>
        </summary>
        <div class="mt-2">
            <textarea
                x-model="note"
                @input="saveNote()"
                class="form-input w-full text-sm resize-none"
                rows="3"
                maxlength="<?= (int)$maxLength ?>"
                placeholder="<?= $escaper->escapeHtmlAttr(__($placeholder)) ?>"
            ></textarea>
            <p class="text-xs text-gray-400 mt-1 mb-0">
                <span x-text="note.length">0</span>/<?= (int)$maxLength ?> <?= $escaper->escapeHtml(__('characters')) ?>
            </p>
        </div>
    </details>
</div>
