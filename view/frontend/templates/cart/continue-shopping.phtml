<?php
/**
 * Panth AdvancedCart - Continue Shopping Button (Hyva)
 *
 * @var $block \Magento\Framework\View\Element\Template
 * @var $escaper \Magento\Framework\Escaper
 */
declare(strict_types=1);

/** @var \Panth\AdvancedCart\ViewModel\CartEnhancements $viewModel */
$viewModel = $block->getData('view_model');

if (!$viewModel->isFeatureEnabled('continue_shopping')) {
    return;
}

$label = $viewModel->getContinueShoppingLabel();
$url = $viewModel->getContinueShoppingUrl();
?>

<div class="panth-continue-shopping mb-4">
    <a href="<?= $escaper->escapeUrl($url) ?>"
       class="inline-flex items-center gap-2 text-sm text-primary hover:text-primary-darker transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        <?= $escaper->escapeHtml(__($label)) ?>
    </a>
</div>
